{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "triage-report.schema.json",
  "type": "object",
  "required": ["summary", "findings"],
  "properties": {
    "summary": {
      "type": "object",
      "required": ["must_fix", "should_fix", "info", "suppressed", "scan_timestamp", "scan_root"],
      "properties": {
        "must_fix": { "type": "integer" },
        "should_fix": { "type": "integer" },
        "info": { "type": "integer" },
        "suppressed": { "type": "integer" },
        "scan_timestamp": { "type": "string", "format": "date-time" },
        "scan_root": { "type": "string" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "title", "cwe", "severity", "location", "evidence_chain", "validator_verdict", "justification", "reproducibility"],
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string", "enum": ["must_fix", "should_fix", "info"] },
          "title": { "type": "string" },
          "cwe": { "type": "array", "items": { "type": "string" } },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
          "location": {
            "type": "object",
            "required": ["file", "line_start", "line_end"],
            "properties": {
              "file": { "type": "string" },
              "line_start": { "type": "integer" },
              "line_end": { "type": "integer" },
              "module": { "type": "string" }
            }
          },
          "entry_point": { "type": "object" },
          "evidence_chain": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["step", "claim", "file", "lines", "quote"],
              "properties": {
                "step": { "type": "integer" },
                "claim": { "type": "string" },
                "file": { "type": "string" },
                "lines": { "type": "array", "items": { "type": "integer" } },
                "quote": { "type": "string" }
              }
            }
          },
          "validator_verdict": {
            "type": "object",
            "required": ["classification", "confidence"],
            "properties": {
              "classification": { "type": "string", "enum": ["reachable-exploitable", "reachable-conditional", "unreachable", "insufficient-context"] },
              "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
              "assumptions": { "type": "array", "items": { "type": "string" } }
            }
          },
          "detected_by": { "type": "array", "items": { "type": "string" } },
          "remediation": {
            "type": "object",
            "properties": {
              "summary": { "type": "string" },
              "references": { "type": "array", "items": { "type": "string" } }
            }
          },
          "justification": { "type": "string" },
          "reproducibility": {
            "type": "object",
            "required": ["context_bundle_hash", "prompt_hash", "model"],
            "properties": {
              "tool_versions_lock": { "type": "string" },
              "context_bundle_hash": { "type": "string" },
              "prompt_hash": { "type": "string" },
              "model": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
